```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.css.map

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Coverage reports
coverage/
htmlcov/
.coverage

# Temporary files
*.tmp
*.temp
*.bak

# OS generated files
.DS_Store
Thumbs.db

# Compiled files
*.exe
*.dll
*.so
*.a
*.o
*.obj
*.out

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# Cache directories
.mypy_cache/
.pytest_cache/
.target/
.gradle/
```